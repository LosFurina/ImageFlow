# Frontend runtime config
# The Docker/Next runtime resolves backend URL via /api/config.
# Leave IMAGEFLOW_PUBLIC_BACKEND_URL empty for host-based auto resolution:
# - localhost:3000 -> localhost:8686
# - 192.168.x.x:3000 -> 192.168.x.x:8686
# Set it for public reverse proxy/domain deployments.
IMAGEFLOW_BACKEND_PORT=8686
IMAGEFLOW_PUBLIC_BACKEND_URL=
NEXT_PUBLIC_REMOTE_PATTERNS=
