FROM node:slim

WORKDIR /app

COPY frontend/package*.json ./
RUN npm install

COPY frontend/ ./

# Public backend URL is resolved at runtime by /api/config.
# Optional runtime envs:
#   IMAGEFLOW_PUBLIC_BACKEND_URL=https://api.example.com
#   IMAGEFLOW_BACKEND_PORT=8686
#   NEXT_PUBLIC_REMOTE_PATTERNS=api.example.com
RUN npm install dotenv

ENV NODE_ENV=production

EXPOSE 3000

COPY <<EOF /app/start.sh
#!/bin/sh
npm run build
npm start
EOF

RUN chmod +x /app/start.sh

CMD ["/app/start.sh"]
